# Copy this file to .env (project root) or Back-end/.env and fill in real values.
# server.js loads both locations, so either works — pick one and be consistent.
# Never commit the real .env file (it's already gitignored).

# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Frontend origin, used for links in emails (verification, password reset, etc.)
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/zyft

# ── Auth ────────────────────────────────────────────────────────────────
# Long, random, unguessable strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
SESSION_SECRET=

# ── Google OAuth ────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Facebook OAuth ──────────────────────────────────────────────────────
# https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Cloudinary (avatar / post image uploads) ───────────────────────────
# https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Outgoing email (verification, password reset) ──────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Zyft <no-reply@zyft.app>"